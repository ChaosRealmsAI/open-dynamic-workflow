{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open Dynamic Workflow Manifest",
  "type": "object",
  "required": ["name", "description", "phases", "agents"],
  "properties": {
    "name": { "type": "string" },
    "description": { "type": "string" },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string" },
          "detail": { "type": "string" }
        }
      }
    },
    "agents": {
      "type": "array",
      "items": { "type": "string" }
    },
    "schemas": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
