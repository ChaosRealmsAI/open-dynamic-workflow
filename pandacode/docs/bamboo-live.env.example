# Copy to .pandacode/bamboo/live.env and fill real values.
# .pandacode/bamboo/live.env is intentionally git-ignored.

export DEEPSEEK_API_KEY="..."
export XIAOMI_API_KEY="..."
export KIMI_API_KEY="..."
export ZHIPU_API_KEY="..."
export MINIMAX_API_KEY="..."
export QWEN_API_KEY="..."
export STEPFUN_API_KEY="..."

# Optional model overrides for live smoke/evals.
export DEEPSEEK_MODEL="deepseek-v4-pro"
export XIAOMI_MODEL="mimo-v2.5-pro"
export KIMI_MODEL="kimi-k2.6"
export ZHIPU_MODEL="glm-5.1"
export MINIMAX_MODEL="MiniMax-M3"
export QWEN_MODEL="qwen3.7-max"
export STEPFUN_MODEL="step-3.7-flash"

export PANDACODE_BAMBOO_PROVIDERS="deepseek xiaomi kimi zhipu minimax qwen stepfun"
