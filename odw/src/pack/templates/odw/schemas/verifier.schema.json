{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open Dynamic Workflow Verifier Result",
  "type": "object",
  "required": ["accepted", "rejected", "needs_more_evidence"],
  "properties": {
    "accepted": { "type": "array", "items": {} },
    "rejected": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "reason"],
        "properties": {
          "claim": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "needs_more_evidence": { "type": "array", "items": {} }
  }
}
