{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open Dynamic Workflow Dynamic Task Plan",
  "type": "object",
  "required": ["status", "summary", "tasks", "join", "quality"],
  "properties": {
    "status": { "enum": ["planned", "needs_input", "failed"] },
    "summary": { "type": "string" },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "prompt", "agentType", "depends_on", "verification"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "prompt": { "type": "string" },
          "agentType": { "type": "string" },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "files": { "type": "array", "items": { "type": "string" } },
          "verification": { "type": "array", "items": { "type": "string" } },
          "risk": { "type": "string" }
        }
      }
    },
    "join": {
      "type": "object",
      "required": ["strategy", "expected_outputs"],
      "properties": {
        "strategy": { "enum": ["all", "any", "quorum"] },
        "quorum": { "type": "integer", "minimum": 1 },
        "expected_outputs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "quality": {
      "type": "object",
      "required": ["max_rework_iterations", "acceptance"],
      "properties": {
        "max_rework_iterations": { "type": "integer", "minimum": 0 },
        "acceptance": { "type": "array", "items": { "type": "string" } }
      }
    },
    "questions": { "type": "array", "items": {} },
    "risks": { "type": "array", "items": { "type": "string" } }
  }
}
