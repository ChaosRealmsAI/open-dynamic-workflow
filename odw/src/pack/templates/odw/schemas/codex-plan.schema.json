{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open Dynamic Workflow Codex Plan Result",
  "type": "object",
  "required": ["status", "plan", "constraints", "verification"],
  "properties": {
    "run_id": { "type": "string" },
    "thread_id": { "type": "string" },
    "status": { "enum": ["planned", "needs_input", "failed"] },
    "adapter": {
      "type": "object",
      "required": ["backend", "mode"],
      "properties": {
        "backend": { "enum": ["codexctl", "pandacode"] },
        "runtime": { "type": "string" },
        "mode": { "enum": ["plan", "session_start"] },
        "command": { "type": "string" },
        "stdout_tail": { "type": "string" },
        "stderr_tail": { "type": "string" }
      }
    },
    "plan": {
      "type": "object",
      "required": ["summary", "steps"],
      "properties": {
        "summary": { "type": "string" },
        "steps": { "type": "array", "items": { "type": "string" } },
        "files": { "type": "array", "items": { "type": "string" } }
      }
    },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "verification": { "type": "array", "items": { "type": "string" } },
    "questions": { "type": "array", "items": {} },
    "risks": { "type": "array", "items": { "type": "string" } },
    "error": {
      "type": ["object", "null"],
      "properties": {
        "category": { "type": "string" },
        "message": { "type": "string" },
        "retryable": { "type": "boolean" },
        "next_action": { "type": "string" }
      }
    }
  }
}
