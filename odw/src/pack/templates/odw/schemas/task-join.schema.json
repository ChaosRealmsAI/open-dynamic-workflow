{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open Dynamic Workflow Task Join Result",
  "type": "object",
  "required": ["status", "summary", "items", "failed", "review_targets"],
  "properties": {
    "status": { "enum": ["joined", "partial", "failed"] },
    "summary": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "status"],
        "properties": {
          "task_id": { "type": "string" },
          "status": { "type": "string" },
          "run_id": { "type": "string" },
          "changed_files": { "type": "array", "items": { "type": "string" } },
          "verification": { "type": "array", "items": {} },
          "evidence": {}
        }
      }
    },
    "failed": { "type": "array", "items": {} },
    "review_targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "evidence"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "evidence": {}
        }
      }
    }
  }
}
