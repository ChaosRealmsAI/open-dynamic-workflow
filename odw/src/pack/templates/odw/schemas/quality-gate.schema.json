{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open Dynamic Workflow Quality Gate Result",
  "type": "object",
  "required": ["verdict", "score", "accepted", "issues", "rework_tasks", "next_action"],
  "properties": {
    "verdict": { "enum": ["pass", "rework", "fail"] },
    "score": { "type": "number", "minimum": 0 },
    "accepted": { "type": "array", "items": { "type": "string" } },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "claim", "evidence", "required_change"],
        "properties": {
          "severity": { "enum": ["critical", "high", "medium", "low"] },
          "claim": { "type": "string" },
          "evidence": { "type": "string" },
          "required_change": { "type": "string" }
        }
      }
    },
    "rework_tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "prompt", "agentType", "depends_on", "verification"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "prompt": { "type": "string" },
          "agentType": { "type": "string" },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "files": { "type": "array", "items": { "type": "string" } },
          "verification": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "next_action": { "type": "string" }
  }
}
